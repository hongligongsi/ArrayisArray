@echo off
chcp 65001 >nul
echo ==============================================
echo          Git 上传脚本
echo ==============================================
echo.

set /p commitMsg=请输入提交信息（默认：更新代码）: 
if "%commitMsg%"=="" set commitMsg=更新代码

echo.
echo ==============================================
echo 开始上传代码...
echo ==============================================
echo.

echo 1. 添加所有更改...
git add .

echo 2. 提交更改...
git commit -m "%commitMsg%"

echo 3. 推送到远程仓库...
git push origin main

if %errorlevel%==0 (
    echo.
    echo ==============================================
    echo ✅ 代码上传成功！
    echo ==============================================
) else (
    echo.
    echo ==============================================
    echo ❌ 代码上传失败，请检查网络连接或稍后重试
    echo ==============================================
)

echo.
echo 按任意键退出...
pause >nul